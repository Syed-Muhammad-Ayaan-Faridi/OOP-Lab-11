public class AverageCalculator {
    public static void main(String[] args) {

        if (args == null || args.length == 0) {
            System.out.println("Error: The list is null or empty.");
            return;
        }
        int sum = 0;
        int count = 0;
        for (String arg : args) {
            try {
                int num = Integer.parseInt(arg);
                sum += num;
                count++;
            } catch (NumberFormatException e) {
                System.out.println("Skipping invalid input: " + arg);
            }
        }
        if (count == 0) {
            System.out.println("Error: No valid integers found in the list.");
        } else {
            double average = (double) sum / count;
            System.out.println("Average of valid integers: " + average);
        }
    }
}
